{
  "name": "bao-bundler",
  "version": "0.2.0",
  "description": "Bao Bundler is a simple, code-driven, and manifest-aware asset bundler for web projects, built with Bun.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./flows": {
      "import": "./dist/flows.js",
      "types": "./dist/flows.d.ts"
    },
    "./runners": {
      "import": "./dist/runners.js",
      "types": "./dist/runners.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typedoc": "^0.28.17"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "keywords": [
    "bun",
    "bundler",
    "assets"
  ],
  "license": "MIT"
}